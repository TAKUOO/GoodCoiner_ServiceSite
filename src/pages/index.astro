---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/Header.astro";
import Hero from "@/components/Hero.astro";
import Features from "@/components/Features.astro";
import Safety from "@/components/Safety.astro";
import Story from "@/components/Story.astro";
import Pricing from "@/components/Pricing.astro";
import Faq from "@/components/Faq.astro";
import Footer from "@/components/Footer.astro";
---

<BaseLayout title="GoodCoiner - トレードを、感覚から仕組みへ。">
  <Header />
  <main>
    <Hero />
    <div class="relative -mb-px bg-white">
      <div class="relative z-10">
        <Features />
        <Safety />
        <img
          src="/figma/safety/bg.svg"
          alt=""
          aria-hidden="true"
          class="pointer-events-none absolute bottom-[-1px] left-1/2 z-0 w-[max(1438px,100vw)] max-w-none -translate-x-1/2 select-none"
        />
      </div>
    </div>
    <Story />
    <Pricing />
    <Faq />
  </main>
  <Footer />
</BaseLayout>
