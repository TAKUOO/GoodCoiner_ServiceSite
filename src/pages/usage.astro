<script is:inline>
  function initUsageOnPage() {
    const links = document.querySelectorAll("[data-onpage-for]");
    if (!links.length) return;

    const ids = [...links].map((l) => /** @type {HTMLElement} */ (l).dataset.onpageFor).filter(Boolean);
    const headings = ids.map((id) => document.getElementById(id)).filter(Boolean);

    if (!headings.length) return;

    const setActive = (id) => {
      links.forEach((link) => {
        const on = link.dataset.onpageFor === id;
        link.classList.toggle("usage-onpage-link--active", on);
      });
    };

    const pickFromScroll = () => {
      const offset = 120;
      let current = ids[0];
      for (const h of headings) {
        if (h.getBoundingClientRect().top <= offset) current = h.id;
      }
      setActive(current);
    };

    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        pickFromScroll();
        ticking = false;
      });
    };

    pickFromScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll, { passive: true });
  }

  initUsageOnPage();
  document.addEventListener("astro:after-swap", initUsageOnPage);
</script>
