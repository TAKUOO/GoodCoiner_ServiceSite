---
export const prerender = false;

import BaseLayout from "@/layouts/BaseLayout.astro";
import Stripe from "stripe";

const sessionId = Astro.url.searchParams.get("session_id");
let activationToken: string | null = null;
let licenseKey: string | null = null;
let planBadge = "月額";
let errorMsg: string | null = null;

const startDate = new Date().toLocaleDateString("ja-JP", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

if (!sessionId) {
  errorMsg = "セッション情報が見つかりません。";
} else {
  try {
    const stripe = new Stripe(Astro.locals.runtime.env.STRIPE_SECRET_KEY);
    const session = await stripe.checkout.sessions.retrieve(sessionId);
    licenseKey = session.metadata?.licenseKey ?? null;
    planBadge = session.metadata?.plan === "yearly" ? "年額" : "月額";

    if (!licenseKey) {
      errorMsg = "ライセンス情報の取得に失敗しました。";
    } else {
      activationToken = crypto.randomUUID();
      const now = Math.floor(Date.now() / 1000);
      const expiresAt = now + 30 * 60;

      await Astro.locals.runtime.env.DB
        .prepare(
          `INSERT OR REPLACE INTO activation_tokens (token, license_key, expires_at, created_at)
           VALUES (?, ?, ?, ?)`
        )
        .bind(activationToken, licenseKey, expiresAt, now)
        .run();
    }
  } catch {
    errorMsg = "セッション情報の取得に失敗しました。";
  }
}

const deepLink = activationToken ? `goodcoiner://activate?token=${activationToken}` : null;
---

<BaseLayout title="お支払い完了 | GoodCoiner">
  <main class="flex min-h-screen items-center justify-center bg-gradient-to-b from-[#eef0f8] to-white px-6 py-20">
    <div class="flex w-full max-w-sm flex-col items-center gap-8 text-center">

      {errorMsg ? (
        <div class="flex flex-col items-center gap-6">
          <p class="text-[var(--text-secondary)]">{errorMsg}</p>
          <a
            href="/#pricing"
            class="inline-flex min-h-[48px] items-center justify-center rounded-[82px] border-2 border-[var(--border-strong)] px-10 py-2"
          >
            <span class="font-['Noto_Sans_JP'] text-[16px] font-bold text-[var(--text-primary)]">
              料金ページに戻る
            </span>
          </a>
        </div>
      ) : (
        <>
          <div class="flex flex-col gap-2">
            <h1 class="font-['Noto_Sans_JP'] text-[28px] font-black text-[var(--text-primary)]">
              お支払いが完了しました！
            </h1>
            <p class="font-['Noto_Sans_JP'] text-[15px] text-[var(--text-secondary)]">
              {planBadge}プランが有効になりました！
            </p>
          </div>

          <!-- アプリカード -->
          <div class="w-full rounded-[28px] bg-[#0d1421] px-8 py-10 flex flex-col items-center gap-5 shadow-[0_20px_60px_rgba(13,20,33,0.18)]">
            <img
              src="/assets/icons/app-icon.png"
              alt="GoodCoiner"
              class="h-[88px] w-[88px] rounded-[20px] shadow-[0_8px_24px_rgba(0,0,0,0.4)]"
            />
            <div class="flex flex-col items-center gap-2">
              <p class="font-['Noto_Sans_JP'] text-[22px] font-black text-white">
                GoodCoiner
              </p>
              <div class="flex items-center gap-2">
                <span class="rounded-full bg-[#ffcd18] px-3 py-0.5 font-['Noto_Sans_JP'] text-[12px] font-bold text-[#0d1421]">
                  {planBadge}
                </span>
                <span class="font-['Noto_Sans_JP'] text-[13px] text-white/50">
                  ● {startDate}より
                </span>
              </div>
            </div>
          </div>

          {deepLink && (
            <a
              id="open-app-btn"
              href={deepLink}
              class="inline-flex min-h-[52px] w-full items-center justify-center rounded-[82px] bg-[var(--accent-yellow)] px-10 py-2 transition-opacity hover:opacity-90"
            >
              <span class="font-['Noto_Sans_JP'] text-[16px] font-bold text-[var(--text-primary)]">
                アプリで利用を開始する
              </span>
            </a>
          )}

          <p class="font-['Noto_Sans_JP'] text-[12px] text-[var(--text-tertiary)]">
            ボタンを押すとアプリが自動的に起動し、プランが切り替わります。
          </p>

          <!-- フォールバック -->
          <details class="w-full text-left">
            <summary class="cursor-pointer font-['Noto_Sans_JP'] text-[12px] text-[var(--text-tertiary)] hover:underline select-none">
              アプリが起動しない場合
            </summary>
            <div class="mt-3 rounded-[12px] border border-[var(--border-soft)] bg-[#fafafa] p-4">
              <p class="mb-2 font-['Noto_Sans_JP'] text-[11px] text-[var(--text-tertiary)]">
                アプリの設定画面からこのコードを入力してください
              </p>
              <p class="font-avenir select-all break-all text-[13px] font-bold tracking-wider text-[var(--text-primary)]">
                {licenseKey}
              </p>
            </div>
          </details>
        </>
      )}
    </div>
  </main>
</BaseLayout>

<script>
  const btn = document.getElementById("open-app-btn") as HTMLAnchorElement | null;
  if (btn) {
    setTimeout(() => {
      window.location.href = btn.href;
    }, 800);
  }
</script>
