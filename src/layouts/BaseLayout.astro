---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "GoodCoiner",
  description = "トレードを、感覚から仕組みへ。Be a Good Coiner",
} = Astro.props;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <slot />
  </body>
</html>
