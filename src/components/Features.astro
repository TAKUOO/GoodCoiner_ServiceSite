---
const featureCards = [
  {
    title: "現物・信用取引の<br />一元管理トラッカー",
    description:
      "保有している名柄の損益、平均価格、評価損益、損益予測を追跡。複数の取引タイプを横断して、全体像を常に確認できます。",
    image: "/figma/features/tracker.png",
    imageAlt: "現物・信用取引の一元管理トラッカーのイメージ",
    offsetClass: "md:mt-0",
  },
  {
    title: "自動利確予約（現物・信用対応）",
    description:
      "目標利益額を指定して自動利確。感情的な判断を排除し、計画通りのトレードを実現します。",
    image: "/figma/features/auto-take-profit.png",
    imageAlt: "自動利確予約のイメージ",
    offsetClass: "md:mt-[32px]",
  },
  {
    title: "損益・パフォーマンス分析",
    description:
      "日々のトレード結果をカレンダー形式で可視化。モチベーション維持、トレードの傾向を把握し、改善点を明確にします。",
    image: "/figma/features/performance-analysis.png",
    imageAlt: "損益・パフォーマンス分析のイメージ",
    offsetClass: "md:-mt-[8px]",
  },
  {
    title: "トレードルール管理・振り返り",
    description:
      "ルール遵守を記録し、次に活かす。一貫した戦略を維持するための振り返り機能を提供します。",
    image: "/figma/features/rule-review.png",
    imageAlt: "トレードルール管理のイメージ",
    offsetClass: "md:mt-[24px]",
  },
];
---

<section id="features" class="bg-[var(--bg-canvas)] px-5 pb-[140px] pt-[104px] md:px-8">
  <div class="mx-auto max-w-[1440px]">
    <div class="flex flex-col items-center gap-3.5 text-center">
      <p
        class="font-avenir text-[20px] font-bold uppercase leading-5 tracking-[0.32em] text-[var(--text-tertiary)]"
      >
        FEATURES
      </p>
      <h2
        class="font-inter-jp font-black-900 text-center text-[clamp(34px,3.8vw,44px)] font-black leading-[63.8px] tracking-[0.04em] text-[var(--text-primary)]"
      >
        保有データを可視化・分析し<br />成長を加速させよう
      </h2>
    </div>

    <div class="mx-auto mt-[70px] flex max-w-[1060px] flex-wrap justify-start gap-x-[100px] gap-y-[48px]">
      {featureCards.map((card) => (
        <article class:list={["flex w-full max-w-[480px] flex-col gap-10", card.offsetClass]}>
          <div>
            <img
              src={card.image}
              alt={card.imageAlt}
              class="block h-auto w-full"
              loading="lazy"
            />
          </div>

          <div class="flex flex-col gap-6">
            <h3
              class="font-inter-jp text-[30px] font-extrabold leading-[39px] tracking-[0.02em] text-[var(--text-heading-card)]"
            >
              <Fragment set:html={card.title} />
            </h3>
            <p class="text-[16px] leading-[25.6px] text-[var(--text-secondary)]">
              {card.description}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
