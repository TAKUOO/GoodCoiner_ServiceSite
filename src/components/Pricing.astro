---
const plans = [
  {
    name: "FREE",
    subtitle: "14日間の無料トライアル",
    price: "0",
    yenOffset: "left-[4px]",
    cta: "outline",
    features: [
      "FREEプランの全機能",
      "信用取引・レバレッジ管理",
      "カスタマーサポートの優先対応",
      "アカウントのセキュリティ強化",
    ],
  },
  {
    name: "PRO",
    subtitle: "本格的なトレーダー向け",
    price: "1,080",
    cta: "filled",
    badge: "一番人気！",
    features: [
      "FREEプランの全機能",
      "信用取引・レバレッジ管理",
      "カスタマーサポートの優先対応",
      "アカウントのセキュリティ強化",
    ],
  },
  {
    name: "LIFE TIME",
    subtitle: "プロフェッショナル、法人向け",
    price: "9,800",
    cta: "outline",
    features: [
      "FREEプランの全機能",
      "信用取引・レバレッジ管理",
      "カスタマーサポートの優先対応",
      "アカウントのセキュリティ強化",
    ],
  },
];
---

<section id="pricing" class="relative overflow-hidden bg-[var(--bg-surface-muted)] px-5 pb-[140px] pt-[160px] md:px-8">
  <div class="absolute inset-x-0 top-0 h-72 rounded-b-[10500px] bg-white"></div>
  <div class="absolute inset-x-0 bottom-0 h-72 rounded-t-[10500px] bg-white"></div>

  <div class="relative mx-auto max-w-[1094px]">
    <div class="flex flex-col items-center gap-3.5 text-center">
      <p
        class="text-[20px] font-bold leading-5 tracking-[0.32em] text-[var(--text-tertiary)]"
        style="font-family: 'Avenir Next', 'Avenir', -apple-system, BlinkMacSystemFont, sans-serif;"
      >
        料金プラン
      </p>
      <h2 class="text-[clamp(34px,3.8vw,48px)] font-black leading-[1.33] tracking-[0.12em] text-[var(--text-primary)]">
        必要な機能に応じて<br />アップグレードできます
      </h2>
    </div>

    <div class="mt-16 grid gap-6 md:grid-cols-3">
      {plans.map((plan) => (
        <article class:list={[
          "relative rounded-[32px] border-2 border-[var(--border-strong)] bg-[var(--bg-elevated)] px-10 pb-10 pt-24",
          plan.cta === "filled" && "shadow-[0_10px_24px_rgba(0,0,0,0.08)]",
        ]}>
          {plan.badge && (
            <div class="absolute inset-x-0 top-0 flex h-12 items-center justify-center rounded-t-[28px] bg-[var(--accent-yellow)] text-[16px] font-bold leading-8 tracking-[0.04em] text-[var(--text-primary)]">
              {plan.badge}
            </div>
          )}

          <div
            class="text-[24px] font-bold leading-6 tracking-[0.12em] text-[var(--text-primary)]"
            style="font-family: 'Avenir Next', 'Avenir', -apple-system, BlinkMacSystemFont, sans-serif;"
          >
            {plan.name}
          </div>
          <div
            class="mt-8 text-[14px] font-semibold leading-4 tracking-[0.2em] text-[var(--text-tertiary)]"
            style="font-family: 'Avenir Next', 'Avenir', -apple-system, BlinkMacSystemFont, sans-serif;"
          >
            {plan.subtitle}
          </div>

          <div class="mt-8 flex items-end gap-2 text-[var(--text-primary)]">
            <span
              class="pb-1 text-[24px] font-medium leading-6 tracking-[0.12em]"
              style="font-family: 'Avenir Next', 'Avenir', -apple-system, BlinkMacSystemFont, sans-serif;"
            >
              ￥
            </span>
            <span
              class="text-[48px] font-bold leading-[48px]"
              style="font-family: 'Avenir Next', 'Avenir', -apple-system, BlinkMacSystemFont, sans-serif;"
            >
              {plan.price}
            </span>
            <span
              class="pb-1 text-[24px] font-medium leading-6 tracking-[0.12em]"
              style="font-family: 'Avenir Next', 'Avenir', -apple-system, BlinkMacSystemFont, sans-serif;"
            >
              /月
            </span>
          </div>

          <ul class="mt-12 space-y-3">
            {plan.features.map((feature) => (
              <li class="flex items-center gap-2 text-[16px] font-medium leading-4 tracking-[0.04em] text-[var(--text-primary)]">
                <span class:list={[
                  "flex h-6 w-6 items-center justify-center rounded-full",
                  plan.cta === "filled" ? "bg-[var(--accent-yellow)]" : "bg-[var(--text-primary)]",
                ]}>
                  <span class:list={[
                    "h-2.5 w-4 rotate-[-8deg] rounded-sm",
                    plan.cta === "filled" ? "bg-[var(--text-primary)]" : "bg-[var(--text-inverse)]",
                  ]}></span>
                </span>
                {feature}
              </li>
            ))}
          </ul>

          <a
            href="#download"
            class:list={[
              "mt-12 inline-flex w-full justify-center rounded-[82px] px-10 py-2 text-[16px] font-bold leading-8 tracking-[-0.02em]",
              plan.cta === "filled"
                ? "bg-[var(--accent-yellow)] text-[var(--text-primary)]"
                : "outline outline-2 outline-offset-[-2px] outline-[var(--border-strong)] text-[var(--text-primary)]",
            ]}
          >
            このプランで始める
          </a>
        </article>
      ))}
    </div>

    <p class="mt-14 text-center text-[12px] leading-3 tracking-[0.08em] text-[var(--text-tertiary)]">
      ※現在GMOコインユーザーのみ利用可能。順次拡張予定です。
    </p>
  </div>
</section>
