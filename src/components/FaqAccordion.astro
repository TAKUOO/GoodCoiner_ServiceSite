---
export interface FaqEntry {
  question: string;
  answer: string;
  open?: boolean;
}

interface Props {
  items: FaqEntry[];
}

const { items } = Astro.props;
---

<div class="w-full space-y-4">
  {items.map((item) => (
    <details
      class="faq-item group rounded-[8px] bg-[var(--bg-elevated)] p-6 outline outline-2 outline-offset-[-2px] outline-[var(--border-strong)] open:bg-[var(--bg-elevated)]"
      open={item.open}
    >
      <summary class="flex cursor-pointer list-none items-center justify-between gap-4 [&::-webkit-details-marker]:hidden">
        <div class="flex min-w-0 flex-1 items-center gap-4">
          <div class="flex h-[39px] w-[39px] shrink-0 items-center justify-center rounded-[4px] bg-[var(--accent-yellow)] md:h-10 md:w-10">
            <span class="font-avenir text-[24px] font-bold leading-none tracking-[0.04em] text-[var(--text-primary)]">
              Q
            </span>
          </div>
          <div class="min-w-0 text-[16px] font-black leading-[1.3] tracking-[0.04em] text-[var(--text-primary)] md:text-[18px] md:leading-6 md:tracking-[0.08em]">
            {item.question}
          </div>
        </div>

        <div class="faq-icon flex h-10 w-10 shrink-0 items-center justify-center self-start">
          <span class="faq-icon-plus text-[28px] font-bold leading-none text-[var(--text-primary)]">+</span>
          <span class="faq-icon-minus hidden text-[28px] font-bold leading-none text-[var(--text-primary)]">−</span>
        </div>
      </summary>

      <div class="faq-answer-grid">
        <div class="faq-answer-inner mt-6 flex items-start gap-4">
          <div class="flex h-[39px] w-[39px] shrink-0 items-center justify-center rounded-[4px] bg-[var(--text-primary)] md:h-10 md:w-10">
            <span class="font-avenir text-[23px] font-bold leading-none tracking-[0.04em] text-[var(--text-inverse)] md:text-[24px]">
              A
            </span>
          </div>
          <p class="flex-1 text-[14px] font-normal leading-[1.3] text-[var(--text-primary)] md:text-[16px] md:leading-6 md:tracking-[0.04em] md:text-[var(--text-secondary)]">
            {item.answer}
          </p>
        </div>
      </div>
    </details>
  ))}
</div>

<style>
  .faq-item .faq-answer-grid {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 260ms ease;
  }

  .faq-item .faq-answer-inner {
    min-height: 0;
    overflow: hidden;
    opacity: 0;
    transform: translateY(-8px);
    transition:
      opacity 220ms ease,
      transform 260ms ease;
  }

  .faq-item[open] .faq-answer-grid {
    grid-template-rows: 1fr;
  }

  .faq-item[open] .faq-answer-inner {
    opacity: 1;
    transform: translateY(0);
  }

  .faq-item[open] .faq-icon-plus {
    display: none;
  }

  .faq-item[open] .faq-icon-minus {
    display: inline;
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-item .faq-answer-grid,
    .faq-item .faq-answer-inner {
      transition: none;
    }
  }
</style>
