---
const faqs = [
  {
    question: "セキュリティとAPIキーの管理は安全ですか？",
    answer:
      "はい、安全に設計されています。グッドコイナーでは、APIキーやトレードデータを外部サーバーに送信せず、すべてお使いのデバイス内で管理します。そのため、第三者がデータにアクセスすることはなく、安心してご利用いただけます。",
    open: true,
  },
  {
    question: "どの取引所に対応していますか？",
    answer:
      "現在は GMOコイン ユーザー向けに提供しています。対応取引所は今後順次拡張予定です。",
  },
  {
    question: "MacとWindowsどちらでも使えますか？",
    answer:
      "現時点でサイト上に案内されているのは Mac版 ダウンロードです。Windows 版についての明記は現状の案内内にはありません。",
  },
  {
    question: "無料プランに期限はありますか？",
    answer:
      "はい。料金プランの案内では、FREE プランは 14日間の無料トライアル として記載されています。より本格的な利用向けに PRO と LIFE TIME も用意されています。",
  },
  {
    question: "だれでも使用できますか？",
    answer:
      "現時点では、GMOコイン ユーザーを対象に順次提供している段階です。今後、対象ユーザーや対応環境を広げていく予定です。",
  },
];
---

<section class="relative overflow-hidden bg-[var(--bg-surface-muted)] px-6 pb-[96px] pt-0 md:px-8 md:pb-[120px]">
  <img
    src="/figma/faq/bg.svg"
    alt=""
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 top-0 z-0 h-auto w-full select-none"
    loading="lazy"
  />

  <div class="relative z-10 mx-auto max-w-[866px] pt-[65px] md:pt-[140px]">
    <div class="flex flex-col items-center gap-10 md:gap-10">
      <div class="flex flex-col items-center gap-1 text-center md:gap-1">
        <p class="text-[18px] font-black leading-none tracking-[0.08em] text-[var(--text-tertiary)] md:text-[20px] md:leading-5 md:tracking-[0.12em]">
          よくあるご質問
        </p>
        <h2 class="font-avenir text-[44px] font-black leading-[1.45] tracking-[0.04em] text-[var(--text-primary)] md:text-[72px] md:leading-[108px]">
          FAQ
        </h2>
      </div>

      <div class="w-full space-y-4">
        {faqs.map((item) => (
          <details
            class="faq-item group rounded-[8px] bg-[var(--bg-elevated)] p-6 outline outline-2 outline-offset-[-2px] outline-[var(--border-strong)] open:bg-[var(--bg-elevated)]"
            open={item.open}
          >
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 [&::-webkit-details-marker]:hidden">
              <div class="flex min-w-0 flex-1 items-center gap-4">
                <div class="flex h-[39px] w-[39px] shrink-0 items-center justify-center rounded-[4px] bg-[var(--accent-yellow)] md:h-10 md:w-10">
                  <span class="font-avenir text-[24px] font-bold leading-none tracking-[0.04em] text-[var(--text-primary)]">
                    Q
                  </span>
                </div>
                <div class="min-w-0 text-[16px] font-black leading-[1.3] tracking-[0.04em] text-[var(--text-primary)] md:text-[18px] md:leading-6 md:tracking-[0.08em]">
                  {item.question}
                </div>
              </div>

              <div class="faq-icon flex h-10 w-10 shrink-0 items-center justify-center self-start">
                <span class="faq-icon-plus text-[28px] font-bold leading-none text-[var(--text-primary)]">+</span>
                <span class="faq-icon-minus hidden text-[28px] font-bold leading-none text-[var(--text-primary)]">−</span>
              </div>
            </summary>

            <div class="faq-answer-grid">
              <div class="faq-answer-inner mt-6 flex items-start gap-4">
                <div class="flex h-[39px] w-[39px] shrink-0 items-center justify-center rounded-[4px] bg-[var(--text-primary)] md:h-10 md:w-10">
                  <span class="font-avenir text-[23px] font-bold leading-none tracking-[0.04em] text-[var(--text-inverse)] md:text-[24px]">
                    A
                  </span>
                </div>
                <p class="flex-1 text-[14px] font-normal leading-[1.3] text-[var(--text-primary)] md:text-[16px] md:leading-6 md:tracking-[0.04em] md:text-[var(--text-secondary)]">
                  {item.answer}
                </p>
              </div>
            </div>
          </details>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .faq-item .faq-answer-grid {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 260ms ease;
  }

  .faq-item .faq-answer-inner {
    min-height: 0;
    overflow: hidden;
    opacity: 0;
    transform: translateY(-8px);
    transition:
      opacity 220ms ease,
      transform 260ms ease;
  }

  .faq-item[open] .faq-answer-grid {
    grid-template-rows: 1fr;
  }

  .faq-item[open] .faq-answer-inner {
    opacity: 1;
    transform: translateY(0);
  }

  .faq-item[open] .faq-icon-plus {
    display: none;
  }

  .faq-item[open] .faq-icon-minus {
    display: inline;
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-item .faq-answer-grid,
    .faq-item .faq-answer-inner {
      transition: none;
    }
  }
</style>
